{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://eq-gateway.dev/schemas/eq-state/v0.1.json",
  "title": "EQState",
  "description": "The complete, top-level validated payload emitted by the EQ Gateway engine. Mirrors eq-state.schema.ts (Zod) v0.1.",
  "type": "object",
  "required": [
    "schema_version",
    "session",
    "affect",
    "intent",
    "risk",
    "privacy",
    "response_policy",
    "context"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of the schema for compatibility checking"
    },
    "session": {
      "type": "object",
      "description": "Metadata about the ephemeral session",
      "required": ["ephemeral_session_id", "timestamp_local", "device_processing_only"],
      "properties": {
        "ephemeral_session_id": {
          "type": "string",
          "format": "uuid",
          "description": "UUID v4 for this ephemeral session"
        },
        "timestamp_local": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of state capture"
        },
        "device_processing_only": {
          "type": "boolean",
          "description": "True if Tier 0 (fully local processing, no cloud call)"
        }
      },
      "additionalProperties": false
    },
    "affect": {
      "type": "object",
      "description": "Quantitative and qualitative measures of current emotion",
      "required": ["primary", "secondary", "valence", "arousal", "confidence", "evidence_type"],
      "properties": {
        "primary": {
          "$ref": "#/definitions/AffectPrimary",
          "description": "The dominant emotion label"
        },
        "secondary": {
          "type": "array",
          "items": { "$ref": "#/definitions/AffectPrimary" },
          "description": "Nuanced secondary emotions detected in the text"
        },
        "valence": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Valence score: -1.0 (extreme negative) to 1.0 (extreme positive)"
        },
        "arousal": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Arousal score: 0.0 (low energy/calm) to 1.0 (high energy/excited)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Model confidence in affect classification (0.0 to 1.0)"
        },
        "evidence_type": {
          "type": "string",
          "description": "How the signal was derived (e.g., 'semantic_inference')"
        }
      },
      "additionalProperties": false
    },
    "intent": {
      "type": "object",
      "description": "Classification of user intent",
      "required": ["category", "subtype", "confidence"],
      "properties": {
        "category": {
          "$ref": "#/definitions/IntentCategory",
          "description": "The broad category of intent"
        },
        "subtype": {
          "type": "string",
          "description": "A more granular description of the user's specific goal"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Model confidence in intent classification (0.0 to 1.0)"
        }
      },
      "additionalProperties": false
    },
    "risk": {
      "type": "object",
      "description": "Safety assessment for escalation",
      "required": ["level", "signals", "confidence", "requires_local_escalation"],
      "properties": {
        "level": {
          "$ref": "#/definitions/RiskLevel",
          "description": "Current urgency/safety level"
        },
        "signals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Specific signals triggering this level"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Model confidence in risk assessment (0.0 to 1.0)"
        },
        "requires_local_escalation": {
          "type": "boolean",
          "description": "Whether the system must bypass cloud calls for safety"
        }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "description": "Metadata regarding data sanitization",
      "required": [
        "sensitivity_level",
        "raw_text_shared",
        "pii_removed",
        "sensitive_domains_detected",
        "redaction_confidence"
      ],
      "properties": {
        "sensitivity_level": {
          "$ref": "#/definitions/PrivacySensitivity",
          "description": "Determined sensitivity level"
        },
        "raw_text_shared": {
          "type": "boolean",
          "description": "Whether raw unredacted text is being sent to cloud"
        },
        "pii_removed": {
          "type": "boolean",
          "description": "Confirmation that PII has been removed"
        },
        "sensitive_domains_detected": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of sensitive domains detected"
        },
        "redaction_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Model confidence in redaction accuracy (0.0 to 1.0)"
        }
      },
      "additionalProperties": false
    },
    "response_policy": {
      "type": "object",
      "description": "Behavioral constraints for the Large AI",
      "required": [
        "tone",
        "warmth",
        "directness",
        "length",
        "pace",
        "max_followup_questions",
        "format"
      ],
      "properties": {
        "tone": {
          "$ref": "#/definitions/ResponseTone",
          "description": "Desired tone of the response"
        },
        "warmth": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Degree of warmth/empathy (0.0 to 1.0)"
        },
        "directness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Degree of directness/brevity (0.0 to 1.0)"
        },
        "length": {
          "type": "string",
          "enum": ["short", "medium", "long"],
          "description": "Target response length"
        },
        "pace": {
          "type": "string",
          "description": "Expected conversational pace"
        },
        "max_followup_questions": {
          "type": "integer",
          "minimum": 0,
          "description": "Hard limit on follow-up questions per turn"
        },
        "format": {
          "type": "string",
          "description": "Preferred response format"
        }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "description": "Sanitized, anonymized summary of the dialogue",
      "required": ["anonymized_summary", "included_raw_excerpt", "retrieval_notes_included"],
      "properties": {
        "anonymized_summary": {
          "type": "string",
          "description": "Privacy-safe text summary of the dialogue"
        },
        "included_raw_excerpt": {
          "type": "boolean",
          "description": "Whether a specific text excerpt was approved for sharing"
        },
        "retrieval_notes_included": {
          "type": "boolean",
          "description": "Whether retrieval notes are included"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "AffectPrimary": {
      "type": "string",
      "enum": [
        "neutral", "calm", "curious", "pleased", "hopeful",
        "confused", "uncertain", "frustrated", "angry", "sad",
        "anxious", "overwhelmed", "fatigued", "embarrassed",
        "lonely", "excited", "urgent", "unknown"
      ],
      "description": "Valid primary emotional descriptors"
    },
    "IntentCategory": {
      "type": "string",
      "enum": [
        "practical_guidance", "emotional_support", "decision_support",
        "venting", "planning", "clarification", "conflict_navigation",
        "reflection", "task_execution", "creative_help",
        "technical_help", "safety_related", "unknown"
      ],
      "description": "High-level classification of user intent"
    },
    "RiskLevel": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "crisis", "unknown"],
      "description": "Safety urgency levels"
    },
    "PrivacySensitivity": {
      "type": "string",
      "enum": ["public", "low", "medium", "high", "restricted", "unknown"],
      "description": "Privacy sensitivity threshold"
    },
    "ResponseTone": {
      "type": "string",
      "enum": [
        "calm_direct", "gentle_direct", "warm_brief",
        "neutral_professional", "highly_practical", "reflective",
        "encouraging", "minimal", "unknown"
      ],
      "description": "Stylistic instructions for the Large AI"
    }
  }
}
